  "keyFeatures": [
    "Automated TeraBox link distribution across multiple Telegram channels",
    "Google Sheets integration for channel management and tracking",
    "Support for multiple TeraBox domains (terabox.com, nephobox.com, etc.)",
    "Random post forwarding for engagement",
    "User authorization and access control",
    "Webhook-based Telegram bot implementation",
    "Channel subscriber analytics and monitoring"
  ],
  "publicApiSurface": [
    "/start - Initialize bot and check authorization",
    "/add - Add channels to distribution list",
    "/random - Forward random posts to channels",
    "/fetch - Retrieve channel statistics and details",
    "POST /{API_TOKEN} - Telegram webhook endpoint",
    "GET / - Health check and webhook setup",
    "AddChannel(channel_id) - Add channel to database",
    "GetAllChannel() - Retrieve all registered channels",
    "CheckAuthUser(user_id) - Verify user authorization",
    "UpdateTotalPost(msg_id) - Update post counter",
    "GetLastPostId() - Get latest post ID"
  ]
}
